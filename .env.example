# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose 'claude' (default) or 'ollama'
LLM_PROVIDER=claude

# ── Claude settings (required when LLM_PROVIDER=claude) ───────────────────────
ANTHROPIC_API_KEY=your-api-key-here

# Optional: override default models
# CLAUDE_MODEL=claude-opus-4-7
# CLAUDE_FAST_MODEL=claude-haiku-4-5

# ── Ollama settings (required when LLM_PROVIDER=ollama) ───────────────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b          # used for discovery + research agents
# OLLAMA_FAST_MODEL=qwen3:4b      # used for elicitor (optional, falls back to OLLAMA_MODEL)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002

# ── Chrome DevTools Protocol ──────────────────────────────────────────────────
# Chrome must be launched with: chrome --remote-debugging-port=9222
CHROME_DEBUG_PORT=9222
