#!/usr/bin/env node
// CRC: crc-NewsletterCli.md | Seq: seq-cc-bootstrap.md, seq-cc-run.md | R155, R156, R157, R158, R159, R160, R161, R162, R165, R166, R167, R168, R169, R170, R171, R172, R173, R217
//
// The newsletter CLI. Every subcommand starts with a liveness check
// (R156) that maps failures to exit codes 64 / 65 / 66 (R157).

import 'dotenv/config';
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __dirname  = path.dirname(fileURLToPath(import.meta.url));
const PROJECT    = path.dirname(__dirname);
const CACHE_DIR  = path.join(PROJECT, 'cache');
const CONN_FILE  = path.join(CACHE_DIR, 'connection.json');
const PORT       = process.env.PORT || 3002;
const BASE       = `http://localhost:${PORT}`;

const EXIT_OK              = 0;
const EXIT_CATASTROPHIC    = 52;
const EXIT_SERVER_DOWN     = 64;
const EXIT_NO_CONNECTION   = 65;
const EXIT_SESSION_MISMATCH = 66;

// CRC: crc-NewsletterCli.md | R157
function die(code, msg) {
  process.stderr.write(msg + '\n');
  process.exit(code);
}

function readConnection() {
  try { return JSON.parse(fs.readFileSync(CONN_FILE, 'utf8')); } catch { return null; }
}

function writeConnection(conn) {
  fs.mkdirSync(CACHE_DIR, { recursive: true });
  fs.writeFileSync(CONN_FILE, JSON.stringify(conn, null, 2));
}

function clearConnection() {
  try { fs.unlinkSync(CONN_FILE); } catch {}
}

function parseFlags(argv) {
  const opts = {};
  const rest = [];
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a.startsWith('--')) {
      const key = a.slice(2);
      const next = argv[i + 1];
      if (next === undefined || next.startsWith('--')) { opts[key] = true; }
      else { opts[key] = next; i++; }
    } else {
      rest.push(a);
    }
  }
  return { opts, rest };
}

// CRC: crc-NewsletterCli.md | R156, R157
async function ccFetch(path, init = {}) {
  const local = readConnection();
  const sessionId = local?.sessionId;
  const headers = { 'Content-Type': 'application/json', ...(init.headers || {}) };
  if (sessionId) headers['X-CC-Session'] = sessionId;
  let res;
  try {
    res = await fetch(`${BASE}${path}`, { ...init, headers });
  } catch (e) {
    die(EXIT_SERVER_DOWN, `newsletter server not reachable at ${PORT} — start it with \`npm start\`. (${e.message})`);
  }
  return res;
}

async function livenessCheck() {
  const local = readConnection();
  if (!local?.sessionId) {
    die(EXIT_NO_CONNECTION, 'no session connected — run `newsletter connect` first.');
  }
  const res = await ccFetch('/api/cc/connection');
  if (!res.ok) {
    die(EXIT_SERVER_DOWN, `liveness check failed (${res.status})`);
  }
  const body = await res.json();
  if (!body.sessionId) {
    die(EXIT_NO_CONNECTION, 'no session connected — run `newsletter connect` first.');
  }
  if (body.sessionId !== local.sessionId) {
    die(EXIT_SESSION_MISMATCH, 'another Claude Code session is connected; this one is not authorized.');
  }
  return body;
}

// CRC: crc-NewsletterCli.md | R158, R159
async function cmdConnect(opts) {
  const sessionId = opts.session || process.env.CLAUDE_SESSION_ID;
  if (!sessionId) {
    die(2, 'usage: newsletter connect --session <id> [--target-window <id>] [--verbose]');
  }
  const body = {
    sessionId,
    targetWindow: opts['target-window'] || null,
    verbose: !!opts.verbose,
  };
  let res;
  try {
    res = await fetch(`${BASE}/api/cc/connection`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
  } catch (e) {
    die(EXIT_SERVER_DOWN, `newsletter server not reachable at ${PORT} — start it with \`npm start\`. (${e.message})`);
  }
  if (!res.ok) {
    die(EXIT_SERVER_DOWN, `connect failed (${res.status})`);
  }
  writeConnection(body);
  const r = await res.json();
  process.stdout.write(`connected as ${sessionId}${r.takeover ? ' (took over from previous session)' : ''}\n`);
}

// CRC: crc-NewsletterCli.md | R160
async function cmdDisconnect() {
  const local = readConnection();
  if (!local?.sessionId) { clearConnection(); return; }
  const res = await ccFetch('/api/cc/connection', { method: 'DELETE' });
  clearConnection();
  if (res.status === 409) {
    // already disconnected or someone else owns the slot — fine
    return;
  }
  if (!res.ok) {
    die(EXIT_SERVER_DOWN, `disconnect failed (${res.status})`);
  }
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-bootstrap.md | R155, R156, R158, R161
//
// One command that ensures the local session is registered (idempotent)
// and then waits for work. Session id comes from --session <id> when
// provided (the slash command's substituted ${CLAUDE_SESSION_ID}), or
// from process.env.CLAUDE_SESSION_ID as a fallback. Replaces the
// connect-then-wait dance the skill was inventing each cycle.
async function cmdPull(opts) {
  const sessionId = opts.session || process.env.CLAUDE_SESSION_ID;
  if (!sessionId) {
    die(2, 'usage: newsletter pull --session <id>   (or set CLAUDE_SESSION_ID in the environment)');
  }
  const local = readConnection();
  if (!local || local.sessionId !== sessionId) {
    const body = { sessionId };
    let res;
    try {
      res = await fetch(`${BASE}/api/cc/connection`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
    } catch (e) {
      die(EXIT_SERVER_DOWN, `newsletter server not reachable at ${PORT} — start it with \`npm start\`. (${e.message})`);
    }
    if (!res.ok) die(EXIT_SERVER_DOWN, `connect failed (${res.status})`);
    writeConnection(body);
  }
  // Now wait — same loop / same markdown output as cmdWait.
  await cmdWait();
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-bootstrap.md | R161, R162
async function cmdWait() {
  await livenessCheck();
  for (;;) {
    const res = await ccFetch('/api/cc/wait');
    if (res.status === 204) continue;            // server-side timeout, re-poll silently
    if (res.status === 409) {
      const body = await res.json().catch(() => ({}));
      die(body.code || EXIT_SESSION_MISMATCH, body.error || 'session mismatch');
    }
    if (!res.ok) {
      die(EXIT_CATASTROPHIC, `wait failed (${res.status})`);
    }
    const work = await res.json();
    const tabLines = (work.tabs || []).map((t, i) => `  ${i + 1}. ${t.title || '(untitled)'}\n     ${t.url || ''}`).join('\n');
    process.stdout.write([
      `# Work item received`,
      ``,
      `runId: ${work.runId}`,
      `kind:  ${work.kind}`,
      `mode:  ${work.mode || 'fresh'}`,
      ``,
      `Tabs in scope (${(work.tabs || []).length}):`,
      tabLines || '  (none)',
      ``,
      `Next:`,
      `  1. newsletter event run-started '{"runId":"${work.runId}"}'`,
      `  2. newsletter next   ← reads cache/state.json, emits the next phase's prompt.`,
      `  3. Follow the prompt's instructions.`,
      ``,
    ].join('\n'));
    return;
  }
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-run.md | R163, R164
//
// Phase metadata for UI activity-log entries. `phase: 1` and `phase: 2`
// correspond to discover and research so the API-mode banner / stepper
// logic in public/index.html still fires for those two; the rest pass a
// string and the UI just logs them.
const PHASE_META = {
  elicit:   { phase: 'elicit',   label: 'Elicit',   message: 'Reading tabs and deciding whether clarifying questions are needed' },
  discover: { phase: 1,          label: 'Discover', message: 'Fetching tabs and grouping them into thematic clusters' },
  research: { phase: 2,          label: 'Research', message: 'Deepening notable links and writing the newsletter' },
  render:   { phase: 'render',   label: 'Render',   message: 'Generating HTML and PDF' },
  podcast:  { phase: 'podcast',  label: 'Podcast',  message: 'Writing the spoken-word script' },
  done:     { phase: 'done',     label: 'Done',     message: 'Run complete' },
};

// CRC: crc-NewsletterCli.md | Seq: seq-cc-run.md | R163, R164
//
// Subagent-facing prompt retrieval. The orchestrator's `next` emits a
// short dispatch directive; the spawned subagent then runs `prompt`
// to get its full phase prompt. Keeps the orchestrator's context tiny.
async function cmdPrompt() {
  await livenessCheck();
  const { currentPhasePrompt } = await import('../lib/crank.js');
  const out = await currentPhasePrompt();
  process.stdout.write(out);
}

async function cmdNext() {
  await livenessCheck();
  const { nextPhasePrompt } = await import('../lib/crank.js');
  const { readState } = await import('../lib/state.js');
  const prePhase  = readState()?.phase || null;
  const out       = await nextPhasePrompt();
  const postPhase = readState()?.phase || null;
  // Push a phase event when we cross a boundary (not on validation retry,
  // where postPhase === prePhase).
  if (postPhase && postPhase !== prePhase) {
    const meta = PHASE_META[postPhase] || { phase: postPhase, label: postPhase, message: '' };
    await ccFetch('/api/cc/event', {
      method: 'POST',
      body: JSON.stringify({ type: 'phase', data: meta }),
    }).catch(() => {});
  }
  // Silent cost-tail ride-along: each `next` invocation doubles as a
  // cost heartbeat — any model work the agent did during the prior phase
  // gets priced and reported before the next prompt is emitted.
  await pushCostEvents({ silent: true });
  process.stdout.write(out);
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-run.md | R168, R169
async function cmdEvent(_opts, rest) {
  await livenessCheck();
  const [type, ...args] = rest;
  if (!type) die(2, 'usage: newsletter event <type> [json-data]');
  let data = null;
  if (args.length) {
    const joined = args.join(' ');
    try { data = JSON.parse(joined); }
    catch { data = { value: joined }; }
  }
  const res = await ccFetch('/api/cc/event', {
    method: 'POST',
    body: JSON.stringify({ type, data }),
  });
  if (!res.ok) {
    const body = await res.json().catch(() => ({}));
    die(body.code || EXIT_SERVER_DOWN, body.error || `event failed (${res.status})`);
  }
  // Silent cost-tail ride-along: every event push doubles as a heartbeat
  // for cost telemetry. New JSONL bytes get priced and pushed as
  // step_cost events without the agent having to invoke cost-tail.
  await pushCostEvents({ silent: true });
}

async function cmdStatus() {
  // No liveness check — status is informational, useful even when not_connected.
  const res = await ccFetch('/api/cc/status');
  if (!res.ok) die(EXIT_SERVER_DOWN, `status failed (${res.status})`);
  process.stdout.write(JSON.stringify(await res.json(), null, 2) + '\n');
}

// CRC: crc-NewsletterCli.md | R156, R157
//
// Preflight diagnostic. The skill / subagents typically run this at
// the top of each cycle to confirm the world looks the way they
// expect before taking the next action. One markdown blob; no JSON
// parsing on the caller side.
async function cmdHealth() {
  const lines = [];
  const local = readConnection();
  const port = PORT;

  // 1. Server reachability + presence
  let server;
  try {
    const r = await fetch(`${BASE}/api/cc/status`);
    server = await r.json();
    lines.push(`# Newsletter health`);
    lines.push('');
    lines.push(`Server: http://localhost:${port} → reachable`);
  } catch (e) {
    lines.push(`# Newsletter health`);
    lines.push('');
    lines.push(`Server: http://localhost:${port} → UNREACHABLE (${e.message})`);
    lines.push(`Action: start the server with \`npm start\`.`);
    process.stdout.write(lines.join('\n') + '\n');
    return;
  }

  const fmtAgo = (ts) => {
    if (!ts) return 'never';
    const ago = Date.now() - ts;
    if (ago < 1000) return 'just now';
    if (ago < 60_000) return `${Math.floor(ago / 1000)}s ago`;
    if (ago < 3_600_000) return `${Math.floor(ago / 60_000)}m ago`;
    return `${Math.floor(ago / 3_600_000)}h ago`;
  };
  lines.push('');
  lines.push(`Presence:`);
  lines.push(`  state:        ${server.presence}`);
  lines.push(`  sessionId:    ${server.sessionId || '(none)'}`);
  lines.push(`  runId:        ${server.runId || '(none)'}`);
  lines.push(`  waitOpen:     ${server.waitOpen}`);
  lines.push(`  lastEvent:    ${fmtAgo(server.lastEventAt)}`);
  lines.push(`  lastActivity: ${fmtAgo(server.lastActivity)}`);
  lines.push('');

  // 2. Local connection match
  if (!local?.sessionId) {
    lines.push(`Local connection: NOT REGISTERED`);
    lines.push(`Action: run \`newsletter pull --session \${CLAUDE_SESSION_ID}\` to register and wait for work.`);
  } else if (!server.sessionId) {
    lines.push(`Local connection: cache/connection.json has ${local.sessionId}`);
    lines.push(`Server connection: NONE`);
    lines.push(`Action: re-run \`newsletter pull --session \${CLAUDE_SESSION_ID}\` — server forgot us.`);
  } else if (server.sessionId !== local.sessionId) {
    lines.push(`Local connection: ${local.sessionId}`);
    lines.push(`Server connection: ${server.sessionId} — MISMATCH`);
    lines.push(`Another CC session has taken over. This one is no longer authorized; stop the loop.`);
  } else {
    lines.push(`Local connection: ${local.sessionId} ✓ (matches server)`);
  }
  lines.push('');

  // 3. Recent session JSONLs in this project
  try {
    const projectDir = path.join(process.env.HOME || '', '.claude/projects', process.cwd().replace(/[^a-zA-Z0-9]/g, '-'));
    const files = fs.readdirSync(projectDir)
      .filter(f => f.endsWith('.jsonl'))
      .map(f => {
        const full = path.join(projectDir, f);
        const stat = fs.statSync(full);
        return { name: f, mtime: stat.mtimeMs, size: stat.size };
      })
      .sort((a, b) => b.mtime - a.mtime)
      .slice(0, 3);
    if (files.length) {
      lines.push(`Recent project session JSONLs:`);
      for (const f of files) {
        const sizeKb = Math.round(f.size / 1024);
        lines.push(`  ${f.name}  ${sizeKb}K  ${fmtAgo(f.mtime)}`);
      }
    } else {
      lines.push(`No session JSONLs found at ${projectDir}.`);
    }
  } catch (e) {
    lines.push(`Could not list project sessions: ${e.message}`);
  }
  lines.push('');

  process.stdout.write(lines.join('\n'));
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-run.md | R165
async function cmdFetch(_opts, rest) {
  await livenessCheck();
  const [url] = rest;
  if (!url) die(2, 'usage: newsletter fetch <url>');
  const res = await ccFetch('/api/cc/fetch', {
    method: 'POST',
    body: JSON.stringify({ url }),
  });
  if (!res.ok) {
    const body = await res.json().catch(() => ({}));
    die(EXIT_SERVER_DOWN, body.error || `fetch failed (${res.status})`);
  }
  const body = await res.json();
  process.stdout.write(body.text || '');
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-run.md | R166
async function cmdSearch(_opts, rest) {
  await livenessCheck();
  const query = rest.join(' ');
  if (!query) die(2, 'usage: newsletter search <query>');
  const res = await ccFetch('/api/cc/search', {
    method: 'POST',
    body: JSON.stringify({ query }),
  });
  if (!res.ok) {
    const body = await res.json().catch(() => ({}));
    die(EXIT_SERVER_DOWN, body.error || `search failed (${res.status})`);
  }
  const body = await res.json();
  const results = body.results || [];
  if (!results.length) {
    process.stdout.write(`# Search: ${query}\n\nNo results.\n`);
    return;
  }
  const lines = [`# Search: ${query}`, ''];
  results.forEach((r, i) => {
    lines.push(`${i + 1}. **${r.title || '(no title)'}**`);
    if (r.url)     lines.push(`   ${r.url}`);
    if (r.snippet) lines.push(`   ${r.snippet}`);
    lines.push('');
  });
  process.stdout.write(lines.join('\n'));
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-run.md | R167
async function cmdRender() {
  await livenessCheck();
  const { renderNewsletterHTML } = await import('../htmlRenderer.js');
  const newsletterPath = path.join(PROJECT, 'cache/newsletter.json');
  if (!fs.existsSync(newsletterPath)) {
    die(EXIT_CATASTROPHIC, 'cache/newsletter.json missing — research phase incomplete.');
  }
  const newsletter = JSON.parse(fs.readFileSync(newsletterPath, 'utf8'));
  if (!newsletter.generatedAt) {
    newsletter.generatedAt = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    fs.writeFileSync(newsletterPath, JSON.stringify(newsletter, null, 2));
  }
  const html = renderNewsletterHTML(newsletter);
  fs.writeFileSync(path.join(PROJECT, 'cache/newsletter.html'), html, 'utf8');
  // PDF generation goes through the server (uses CDP printToPDF + the served HTML)
  const pdfRes = await ccFetch('/api/cc/render-pdf', { method: 'POST', body: '{}' });
  let pdfPath = null;
  if (pdfRes.status === 404) {
    process.stdout.write('newsletter.html written. (PDF rendering endpoint not yet wired.)\n');
  } else if (!pdfRes.ok) {
    process.stdout.write(`newsletter.html written; PDF skipped (${pdfRes.status}).\n`);
  } else {
    pdfPath = '/api/newsletter.pdf';
    process.stdout.write('newsletter.html and newsletter.pdf written.\n');
  }
  // CLI pushes the output_ready event itself — the paths are CLI-side knowledge,
  // not agent-side. Avoids the agent guessing payload fields and matches the
  // shape the API-mode server-side path sends (server.js output_ready handler).
  let runId = null;
  try { runId = JSON.parse(fs.readFileSync(path.join(PROJECT, 'cache/run.json'), 'utf8')).runId || null; } catch {}
  await ccFetch('/api/cc/event', {
    method: 'POST',
    body: JSON.stringify({
      type: 'output_ready',
      data: { runId, html: '/api/newsletter.html', pdf: pdfPath },
    }),
  }).catch(() => {});
  await ccFetch('/api/cc/event', {
    method: 'POST',
    body: JSON.stringify({
      type: 'run-finished',
      data: { runId },
    }),
  }).catch(() => {});
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-elicitor.md | R171, R172
//
// One foreground blocking command that pushes questions to the UI
// AND blocks for answers. Replaces the two-step `ask-elicitor` +
// `await-answers` choreography that gave Haiku room to invent
// `tail -f` monitoring (see .scratch/PIG-WRESTLING.md). Stencil
// pattern — one shape the model can't get wrong.
async function cmdElicitAwait(_opts, rest) {
  await livenessCheck();
  // Stdin only, markdown-stencilled. The earlier JSON-in-heredoc form
  // tripped Claude Code's "brace with quote character (expansion
  // obfuscation)" safety check on every call, requiring per-call user
  // approval. The markdown form has no braces and reads naturally:
  //
  //   ./bin/newsletter elicit-await <<'EOF'
  //   **Suggestion:** ...
  //   - Question 1?
  //   - Question 2?
  //   EOF
  if (rest.length) {
    die(2, 'elicit-await: positional file argument is no longer supported. Pipe markdown on stdin via heredoc.');
  }
  if (process.stdin.isTTY) {
    die(2, 'usage: ./bin/newsletter elicit-await <<\'EOF\'\n  **Suggestion:** <one-sentence framing>\n  - <Question 1>\n  - <Question 2>\n  EOF');
  }
  const input = await readStdin();
  if (!input.trim()) die(EXIT_CATASTROPHIC, 'elicit-await: stdin was empty.');
  const questions = parseElicitorMarkdown(input);
  if (!questions.questions.length) {
    die(EXIT_CATASTROPHIC, 'elicit-await: no questions found. Use markdown bullets, e.g.:\n  **Suggestion:** ...\n  - Question 1?\n  - Question 2?');
  }
  // Persist the questions for the diagnostic path / replay.
  fs.mkdirSync(CACHE_DIR, { recursive: true });
  fs.writeFileSync(path.join(CACHE_DIR, 'elicitor-questions.json'), JSON.stringify(questions, null, 2));
  // Push questions
  const pushRes = await ccFetch('/api/cc/event', {
    method: 'POST',
    body: JSON.stringify({ type: 'questions', data: questions }),
  });
  if (!pushRes.ok) die(EXIT_SERVER_DOWN, `elicit-await: pushing questions failed (${pushRes.status})`);
  // Find the runId from cache/run.json so the long-poll URL is well-formed
  const runFile = path.join(PROJECT, 'cache/run.json');
  let runId = '';
  try { runId = JSON.parse(fs.readFileSync(runFile, 'utf8')).runId || ''; } catch {}
  // Block for answers
  for (;;) {
    const res = await ccFetch(`/api/cc/await-answer?runId=${encodeURIComponent(runId)}`);
    if (res.status === 204) continue;          // long-poll timeout, re-poll silently
    if (res.status === 409) {
      const body = await res.json().catch(() => ({}));
      die(body.code || EXIT_SESSION_MISMATCH, body.error || 'session mismatch');
    }
    if (!res.ok) die(EXIT_CATASTROPHIC, `elicit-await: await failed (${res.status})`);
    const answers = await res.json();
    fs.mkdirSync(path.join(PROJECT, 'cache'), { recursive: true });
    fs.writeFileSync(path.join(PROJECT, 'cache/elicitor-qa.json'), JSON.stringify(answers, null, 2));
    const qa = Array.isArray(answers?.qa) ? answers.qa : [];
    if (!qa.length) {
      process.stdout.write([
        `# Elicitor: user skipped`,
        ``,
        `No clarifying answers were provided.`,
        ``,
        `Next:`,
        `  1. Synthesize a 3–5 sentence context block from the tab list alone.`,
        `  2. Submit it: \`./bin/newsletter submit-context <<'EOF' ... EOF\``,
        `  3. Exit; the orchestrator will run \`./bin/newsletter next\` to advance.`,
        ``,
      ].join('\n'));
      return;
    }
    const lines = [`# Elicitor answers received — runId ${runId}`, ''];
    qa.forEach((entry) => {
      lines.push(`Q: ${entry.q || '(no question)'}`);
      lines.push(`A: ${(entry.a && entry.a.trim()) || '(skipped)'}`);
      lines.push('');
    });
    lines.push(`Next:`);
    lines.push(`  1. Synthesize a 3–5 sentence context block from these answers.`);
    lines.push(`  2. Submit it: \`./bin/newsletter submit-context <<'EOF' ... EOF\``);
    lines.push(`  3. Exit; the orchestrator will run \`./bin/newsletter next\` to advance.`);
    lines.push('');
    process.stdout.write(lines.join('\n'));
    return;
  }
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-elicitor.md | R171
// (Kept for testing / fallbacks. Prefer `elicit-await` in production.)
async function cmdAskElicitor(_opts, rest) {
  await livenessCheck();
  const [questionsPath] = rest;
  if (!questionsPath) die(2, 'usage: newsletter ask-elicitor <questions.json>');
  const abs = path.isAbsolute(questionsPath) ? questionsPath : path.join(PROJECT, questionsPath);
  let payload;
  try { payload = JSON.parse(fs.readFileSync(abs, 'utf8')); }
  catch (e) { die(EXIT_CATASTROPHIC, `could not read ${abs}: ${e.message}`); }
  const res = await ccFetch('/api/cc/event', {
    method: 'POST',
    body: JSON.stringify({ type: 'questions', data: payload }),
  });
  if (!res.ok) die(EXIT_SERVER_DOWN, `ask-elicitor failed (${res.status})`);
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-elicitor.md | R172
async function cmdAwaitAnswers(_opts, rest) {
  await livenessCheck();
  const [runId] = rest;
  if (!runId) die(2, 'usage: newsletter await-answers <run-id>');
  for (;;) {
    const res = await ccFetch(`/api/cc/await-answer?runId=${encodeURIComponent(runId)}`);
    if (res.status === 204) continue;        // long-poll timeout, re-poll silently
    if (res.status === 409) {
      const body = await res.json().catch(() => ({}));
      die(body.code || EXIT_SESSION_MISMATCH, body.error || 'session mismatch');
    }
    if (!res.ok) die(EXIT_CATASTROPHIC, `await-answers failed (${res.status})`);
    const body = await res.json();
    fs.mkdirSync(path.join(PROJECT, 'cache'), { recursive: true });
    fs.writeFileSync(path.join(PROJECT, 'cache/elicitor-qa.json'), JSON.stringify(body, null, 2));
    process.stdout.write(JSON.stringify(body) + '\n');
    return;
  }
}

// CRC: crc-NewsletterCli.md | R173
async function cmdAnswer(_opts, rest) {
  // Test/CLI fallback that injects answers without the UI.
  const payload = rest.length ? JSON.parse(rest.join(' ')) : {};
  const res = await fetch(`${BASE}/api/cc/answer`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  }).catch(e => {
    die(EXIT_SERVER_DOWN, `server not reachable: ${e.message}`);
  });
  if (!res.ok) die(EXIT_SERVER_DOWN, `answer failed (${res.status})`);
}

// CRC: crc-NewsletterCli.md | Seq: seq-cc-run.md | R174, R175, R176, R179, R181
//
// Compute and push any newly-priced step_cost events to the server.
// Used directly by `cmdCostTail` and as a silent ride-along by
// `cmdEvent` / `cmdNext` so cost is event-paced without the agent
// having to invoke cost-tail explicitly. Best-effort in silent mode:
// any failure is swallowed so the calling command's main work isn't
// disrupted.
async function pushCostEvents({ silent = false } = {}) {
  const local = readConnection();
  if (!local?.sessionId) {
    if (silent) return;
    die(EXIT_NO_CONNECTION, 'no session connected — run `./bin/newsletter connect` first.');
  }
  const { computeCostEvents } = await import('../lib/cost.js');
  const result = computeCostEvents(local.sessionId);
  if (!result.events.length) return;
  for (const ev of result.events) {
    // Best-effort POST; if server is down, fall back to stdout (R179)
    // — but only in explicit cost-tail mode. Silent ride-along stays silent.
    const r = await fetch(`${BASE}/api/cc/event`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CC-Session': local.sessionId },
      body: JSON.stringify({ type: 'step_cost', data: ev }),
    }).catch(() => null);
    if (!silent && (!r || !r.ok)) {
      process.stdout.write(`[cost] ${ev.label}: $${ev.cost.toFixed(4)} (${ev.input_tokens}in/${ev.output_tokens}out, ${ev.model})\n`);
    }
  }
}

async function cmdCostTail() {
  await pushCostEvents();
}

// CRC: crc-NewsletterCli.md
//
// Read all of stdin to a string. Used by the submit-* commands so
// the agent can pipe content via `<<'EOF' ... EOF` instead of
// reaching for the Write tool.
function readStdin() {
  return new Promise((resolve, reject) => {
    let buf = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', (c) => { buf += c; });
    process.stdin.on('end', () => resolve(buf));
    process.stdin.on('error', reject);
  });
}

// Validate the discover phase's stencilled markdown and write both
// cache/clusters.md (verbatim source) and cache/clusters.json
// (parsed JSON for the renderer / research prompt). Parse / schema
// failures exit 65 with errors on stderr; the agent retries.
async function cmdSubmitClusters() {
  await livenessCheck();
  const input = await readStdin();
  if (!input.trim()) die(2, 'submit-clusters: stdin is empty.');
  const { parseClusters, logParseFailure } = await import('../lib/parseClusters.js');
  const { validateClusters } = await import('../lib/crank.js');
  const { result, errors: parseErrs } = parseClusters(input);
  const runId = readRunId();
  if (parseErrs.length) {
    logParseFailure(CACHE_DIR, 'DISCOVER', runId, input, parseErrs);
    process.stderr.write('Parse errors:\n');
    for (const e of parseErrs) process.stderr.write(`  - ${e}\n`);
    process.exit(65);
  }
  const valErrs = validateClusters(result);
  if (valErrs.length) {
    logParseFailure(CACHE_DIR, 'DISCOVER', runId, input, valErrs);
    process.stderr.write('Validation errors:\n');
    for (const e of valErrs) process.stderr.write(`  - ${e}\n`);
    process.exit(65);
  }
  fs.mkdirSync(CACHE_DIR, { recursive: true });
  fs.writeFileSync(path.join(CACHE_DIR, 'clusters.md'), input);
  fs.writeFileSync(path.join(CACHE_DIR, 'clusters.json'), JSON.stringify(result, null, 2));
  const sourceCount = result.clusters.reduce((n, c) => n + (c.sources?.length || 0), 0);
  process.stdout.write(`OK — ${result.clusters.length} cluster(s), ${sourceCount} source(s) written.\n`);
}

async function cmdSubmitNewsletter() {
  await livenessCheck();
  // Two input modes:
  //   1. stdin (heredoc) — short or moderate content
  //   2. canonical cache file (when stdin empty) — for long content the
  //      agent has written via the Write tool; avoids CC's
  //      long-input heuristic on heredoc Bash commands.
  let input;
  if (process.stdin.isTTY) {
    const cachePath = path.join(CACHE_DIR, 'newsletter.md');
    if (!fs.existsSync(cachePath)) {
      die(2, `submit-newsletter: no stdin and ${cachePath} not found. Either pipe the markdown via heredoc or write it to ${cachePath} first.`);
    }
    input = fs.readFileSync(cachePath, 'utf8');
  } else {
    input = await readStdin();
    if (!input.trim()) {
      // Empty stdin (e.g. </dev/null): fall back to canonical file.
      const cachePath = path.join(CACHE_DIR, 'newsletter.md');
      if (!fs.existsSync(cachePath)) die(2, 'submit-newsletter: stdin is empty and cache/newsletter.md does not exist.');
      input = fs.readFileSync(cachePath, 'utf8');
    }
  }
  const { parseNewsletter, logNewsletterParseFailure } = await import('../lib/parseNewsletter.js');
  const { validateNewsletter } = await import('../lib/crank.js');
  const { result, errors: parseErrs } = parseNewsletter(input);
  const runId = readRunId();
  if (parseErrs.length) {
    logNewsletterParseFailure(CACHE_DIR, runId, input, parseErrs);
    process.stderr.write('Parse errors:\n');
    for (const e of parseErrs) process.stderr.write(`  - ${e}\n`);
    process.exit(65);
  }
  const valErrs = validateNewsletter(result);
  if (valErrs.length) {
    logNewsletterParseFailure(CACHE_DIR, runId, input, valErrs);
    process.stderr.write('Validation errors:\n');
    for (const e of valErrs) process.stderr.write(`  - ${e}\n`);
    process.exit(65);
  }
  fs.mkdirSync(CACHE_DIR, { recursive: true });
  fs.writeFileSync(path.join(CACHE_DIR, 'newsletter.md'), input);
  fs.writeFileSync(path.join(CACHE_DIR, 'newsletter.json'), JSON.stringify(result, null, 2));
  process.stdout.write(`OK — newsletter written: "${result.title}" with ${result.sections.length} section(s).\n`);
}

async function cmdSubmitContext() {
  await livenessCheck();
  const input = await readStdin();
  if (!input.trim()) die(2, 'submit-context: stdin is empty.');
  fs.mkdirSync(CACHE_DIR, { recursive: true });
  fs.writeFileSync(path.join(CACHE_DIR, 'elicitor-context.txt'), input);
  process.stdout.write(`OK — context block written (${input.trim().length} chars).\n`);
}

async function cmdSubmitPodcast() {
  await livenessCheck();
  // Same dual-input pattern as submit-newsletter — long content can
  // go through the Write tool to cache/podcast-script.txt and this
  // command will pick it up when called with no stdin.
  const cachePath = path.join(CACHE_DIR, 'podcast-script.txt');
  let input;
  if (process.stdin.isTTY) {
    if (!fs.existsSync(cachePath)) {
      die(2, `submit-podcast: no stdin and ${cachePath} not found. Either pipe the script via heredoc or write it to ${cachePath} first.`);
    }
    input = fs.readFileSync(cachePath, 'utf8');
  } else {
    input = await readStdin();
    if (!input.trim()) {
      if (!fs.existsSync(cachePath)) die(2, 'submit-podcast: stdin is empty and cache/podcast-script.txt does not exist.');
      input = fs.readFileSync(cachePath, 'utf8');
    }
  }
  fs.mkdirSync(CACHE_DIR, { recursive: true });
  // Idempotent: if the agent already wrote the canonical file via the
  // Write tool, this re-write is a no-op; otherwise persist now.
  fs.writeFileSync(cachePath, input);
  const words = input.trim().split(/\s+/).length;
  process.stdout.write(`OK — podcast script written (${words} words).\n`);
}

function readRunId() {
  try { return JSON.parse(fs.readFileSync(path.join(PROJECT, 'cache/run.json'), 'utf8')).runId || null; }
  catch { return null; }
}

// Parse the elicit-await markdown stencil into the {questions, suggestion}
// shape the UI expects. Markdown form was chosen over JSON because
// brace+quote patterns trigger Claude Code's "expansion obfuscation"
// safety check on every call.
//
// Recognizes:
//   **Suggestion:** <text>     → suggestion (also accepts "Suggestion:" without bold)
//   - <question text>          → questions[]
function parseElicitorMarkdown(text) {
  const lines = text.split(/\r?\n/);
  let suggestion = '';
  const questions = [];
  for (const raw of lines) {
    const line = raw.trim();
    if (!line) continue;
    const mSugg = /^(?:\*\*)?suggestion:?(?:\*\*)?\s*(.+)$/i.exec(line);
    if (mSugg) { suggestion = mSugg[1].trim(); continue; }
    const mBullet = /^[-*]\s+(.+)$/.exec(line);
    if (mBullet) { questions.push(mBullet[1].trim()); continue; }
  }
  return { questions, suggestion };
}

// CRC: crc-NewsletterCli.md
//
// One-line descriptions per subcommand, grouped by use. Subagents
// reach for `--help` by reflex even when their agent file lists what
// they need; this gives them a real answer instead of a usage line.
async function cmdHelp() {
  process.stdout.write([
    'usage: ./bin/newsletter <subcommand> [args]',
    '',
    'Inside-out newsletter pipeline CLI. Run from this project\'s root.',
    '',
    'Connection / loop:',
    '  pull --session <id>      register session and block for work (preferred bootstrap)',
    '  connect --session <id>   register without blocking',
    '  disconnect               clear registration',
    '  wait                     block for next work item',
    '  next                     advance state; emit dispatch directive (orchestrator)',
    '  prompt                   emit current phase\'s full prompt (subagent)',
    '  health                   preflight diagnostic (server, presence, JSONL state)',
    '  status                   raw status JSON',
    '',
    'Phase artifacts — subagents pipe content via heredoc:',
    '  submit-clusters    <stdin> = cache/clusters.md  (parses + validates)',
    '  submit-newsletter  <stdin> = cache/newsletter.md (parses + validates)',
    '  submit-context     <stdin> = cache/elicitor-context.txt',
    '  submit-podcast     <stdin> = cache/podcast-script.txt',
    '',
    'Phase tools:',
    '  fetch <url>              fetch a page via CDP (returns text + date)',
    '  search \'<query>\'         web search via CDP (single-quote the query)',
    '  elicit-await             push questions on stdin, block for answers',
    '',
    'Status / lifecycle:',
    '  event <type> <json>      push a status event to the UI',
    '  cost-tail                compute and push cost events',
    '  cost-summary             print cost totals to stdout',
    '  render                   generate HTML/PDF; push output_ready + run-finished',
    '',
    'Subagents: your full instructions for the current phase live in',
    '`./bin/newsletter prompt`. Run that first; the output tells you what to do.',
    '',
  ].join('\n'));
}

// CRC: crc-NewsletterCli.md | R181
async function cmdCostSummary() {
  const local = readConnection();
  if (!local?.sessionId) die(EXIT_NO_CONNECTION, 'no session connected — run `newsletter connect` first.');
  const { computeCostEvents } = await import('../lib/cost.js');
  const result = computeCostEvents(local.sessionId);
  // Aggregate by agent
  const byAgent = new Map();
  for (const ev of result.events) {
    const cur = byAgent.get(ev.agent) || { cost: 0, count: 0 };
    cur.cost  += ev.cost;
    cur.count += 1;
    byAgent.set(ev.agent, cur);
  }
  for (const [agent, info] of byAgent) {
    process.stdout.write(`${agent}: $${info.cost.toFixed(4)} (${info.count} step${info.count !== 1 ? 's' : ''})\n`);
  }
  process.stdout.write(`Total: $${result.total.toFixed(4)}\n`);
}

const subcommands = {
  connect:         cmdConnect,
  disconnect:      cmdDisconnect,
  pull:            cmdPull,
  wait:            cmdWait,
  next:            cmdNext,
  prompt:          cmdPrompt,
  event:           cmdEvent,
  'submit-clusters':   cmdSubmitClusters,
  'submit-newsletter': cmdSubmitNewsletter,
  'submit-context':    cmdSubmitContext,
  'submit-podcast':    cmdSubmitPodcast,
  fetch:           cmdFetch,
  search:          cmdSearch,
  render:          cmdRender,
  'elicit-await':  cmdElicitAwait,
  'ask-elicitor':  cmdAskElicitor,    // legacy / testing — see PIG-WRESTLING.md
  'await-answers': cmdAwaitAnswers,   // legacy / testing
  answer:          cmdAnswer,
  'cost-tail':     cmdCostTail,
  'cost-summary':  cmdCostSummary,
  status:          cmdStatus,
  health:          cmdHealth,
  help:            cmdHelp,
  '--help':        cmdHelp,
  '-h':            cmdHelp,
};

const [, , sub, ...rawArgs] = process.argv;
if (!sub || !(sub in subcommands)) {
  process.stderr.write(`usage: newsletter <${Object.keys(subcommands).join('|')}> [args]\n`);
  process.stderr.write(`Run \`./bin/newsletter help\` for a grouped list with descriptions.\n`);
  process.exit(2);
}
const { opts, rest } = parseFlags(rawArgs);
// Any --help / -h flag (regardless of position) routes to cmdHelp.
// Subagents reach for `subcmd --help` by reflex; without this they'd
// block on stdin or get confusing usage errors.
if (opts.help || opts.h) {
  cmdHelp().catch(e => die(EXIT_CATASTROPHIC, e.stack || String(e)));
} else {
  try {
    const result = subcommands[sub](opts, rest);
    if (result instanceof Promise) result.catch(e => die(EXIT_CATASTROPHIC, e.stack || String(e)));
  } catch (e) {
    die(EXIT_CATASTROPHIC, e.stack || String(e));
  }
}
